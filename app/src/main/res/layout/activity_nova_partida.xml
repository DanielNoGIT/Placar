<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#15151F"
    android:padding="24dp">

    <TextView
        android:id="@+id/textVoltar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="←  Nova Partida"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/labelNomeJogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Nome do jogo"
        android:textColor="#A0A0B0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textVoltar" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardNomeJogo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:cardBackgroundColor="#212130"
        app:cardCornerRadius="12dp"
        app:strokeColor="#8A8AFF"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/labelNomeJogo">

        <EditText
            android:id="@+id/editNomeJogo"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:color/transparent"
            android:hint="Ex: Truco da Família"
            android:paddingHorizontal="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#5A5A70" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/labelJogadores"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Jogadores"
        android:textColor="#A0A0B0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardNomeJogo" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerJogadoresNovaPartida"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        app:layout_constraintTop_toBottomOf="@id/labelJogadores"
        tools:layout_editor_absoluteX="24dp" />

    <Button
        android:id="@+id/btnAdicionarJogador"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="+ Adicionar jogador"
        android:textColor="#8A8AFF"
        app:strokeColor="#8A8AFF"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/recyclerJogadoresNovaPartida" />

    <TextView
        android:id="@+id/labelPontuacao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Pontuação máxima (opcional)"
        android:textColor="#A0A0B0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnAdicionarJogador" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPontuacao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:cardBackgroundColor="#212130"
        app:cardCornerRadius="12dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/labelPontuacao">

        <EditText
            android:id="@+id/editPontuacaoMaxima"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:color/transparent"
            android:hint="Ex: 12"
            android:inputType="number"
            android:paddingHorizontal="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#5A5A70" />
    </com.google.android.material.card.MaterialCardView>

    <Button
        android:id="@+id/btnIniciarPartida"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Iniciar Partida"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="#8A8AFF"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>