<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#15151F"
    android:padding="24dp">

    <TextView
        android:id="@+id/textNomeJogoHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="←  Truco da Família"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textRodada"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Rodada 4 de 12"
        android:textColor="#A0A0B0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textNomeJogoHeader" />

    <ProgressBar
        android:id="@+id/progressBarPartida"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:progress="33"
        android:progressTint="#8A8AFF"
        android:backgroundTint="#212130"
        app:layout_constraintTop_toBottomOf="@id/textRodada" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerJogadoresPlacar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/progressBarPartida"
        app:layout_constraintBottom_toTopOf="@id/btnEncerrarPartida" />

    <Button
        android:id="@+id/btnEncerrarPartida"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Encerrar Partida"
        android:textColor="#FF5A5A"
        app:strokeColor="#FF5A5A"
        app:strokeWidth="1dp"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>